{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai_scenario_grid",
  "title": "AI 场景网格",
  "description": "展示 AI 工具或大模型辅助场景,结构与 scenario_grid 相同。",
  "type": "object",
  "required": [
    "scenes"
  ],
  "additionalProperties": false,
  "properties": {
    "scenes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "description": "AI 场景卡片列表",
      "items": {
        "type": "object",
        "description": "场景卡片",
        "required": [
          "title",
          "tools"
        ],
        "additionalProperties": false,
        "properties": {
          "caption": {
            "type": "string",
            "minLength": 3,
            "maxLength": 10,
            "description": "兼容字段。新数据优先使用 title,旧数据可继续被 renderer 读取。"
          },
          "tools": {
            "type": "array",
            "minItems": 0,
            "maxItems": 5,
            "description": "工具或业务系统标签",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 12,
              "description": "工具或系统名"
            }
          },
          "screenshot": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "可选截图文件名,渲染时由 Python 检查是否存在"
          },
          "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 10,
            "description": "场景标题,使用动词+名词的完整语义词组,核心场景 3-10 字;极限情况按具体业务微调"
          },
          "description": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80,
            "description": "AI 辅助场景的一句话说明,放在卡片标题下方"
          },
          "evidence_quotes": {
            "type": "array",
            "minItems": 0,
            "maxItems": 4,
            "description": "支撑该 AI 场景的访谈原话",
            "items": {
              "type": "object",
              "required": [
                "quote",
                "source"
              ],
              "additionalProperties": false,
              "properties": {
                "quote": {
                  "type": "string",
                  "minLength": 2,
                  "maxLength": 200
                },
                "source": {
                  "type": "string",
                  "minLength": 2,
                  "maxLength": 20
                }
              }
            }
          }
        }
      }
    },
    "module_title": {
      "type": "string",
      "minLength": 2,
      "maxLength": 12,
      "description": "可选模块标题,默认 AI 辅助场景"
    }
  }
}
