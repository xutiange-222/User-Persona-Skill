{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tob_journey_l1",
  "title": "toB 全景 UML 泳道旅程图",
  "description": "多角色多阶段 UML 风格泳道流程图。LLM 只提供 nodes 和 edges DSL,Python 负责 deterministic 几何计算。",
  "type": "object",
  "required": [
    "banner_title",
    "banner_subtitle",
    "stages",
    "lanes",
    "nodes",
    "edges"
  ],
  "additionalProperties": false,
  "properties": {
    "banner_title": {
      "type": "string",
      "minLength": 4,
      "maxLength": 30,
      "description": "顶部主标题"
    },
    "banner_subtitle": {
      "type": "string",
      "maxLength": 50,
      "description": "顶部副标题"
    },
    "note": {
      "type": "string",
      "maxLength": 220,
      "description": "可选底部说明"
    },
    "stages": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "description": "流程阶段",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "subStages"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$",
            "maxLength": 20
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 8
          },
          "subStages": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
              "type": "string",
              "maxLength": 6
            }
          }
        }
      }
    },
    "lanes": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "description": "泳道角色",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$",
            "maxLength": 20
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 6
          },
          "tag": {
            "type": "string",
            "maxLength": 6
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "description": "UML 节点 DSL",
      "items": {
        "type": "object",
        "required": [
          "id",
          "lane",
          "stage",
          "type",
          "label"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^n[0-9]+$",
            "maxLength": 8
          },
          "lane": {
            "type": "string",
            "maxLength": 20
          },
          "stage": {
            "type": "string",
            "maxLength": 20
          },
          "type": {
            "type": "string",
            "enum": [
              "start",
              "end",
              "step",
              "action",
              "decision",
              "doc"
            ]
          },
          "slot": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          },
          "label": {
            "type": "string",
            "minLength": 2,
            "maxLength": 16
          },
          "track": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1,
            "description": "同一 slot 内的纵向轨道(0=上轨,1=下轨),用于密集场景节点错位避免重叠"
          },
          "row": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1,
            "description": "track 字段的兼容别名(旧 JSON 用 row,新写法用 track)"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 0,
      "maxItems": 50,
      "description": "UML 连线 DSL",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": false,
        "properties": {
          "from": {
            "type": "string",
            "pattern": "^n[0-9]+$"
          },
          "to": {
            "type": "string",
            "pattern": "^n[0-9]+$"
          },
          "branch": {
            "type": "string",
            "enum": [
              "yes",
              "no"
            ]
          },
          "style": {
            "type": "string",
            "enum": [
              "solid",
              "dashed"
            ]
          }
        }
      }
    }
  }
}
