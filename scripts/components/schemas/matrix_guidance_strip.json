{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "matrix_guidance_strip",
  "title": "矩阵读图引导条",
  "description": "矩阵首页顶部读图引导:1-3 个轴/分布的解读条目。每条 = 「带轴前缀的 label + 单句 hint」。典型用法:1 条说 X 轴含义、1 条说 Y 轴含义,可选 1 条说分布判断。",
  "type": "object",
  "required": [
    "items"
  ],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "description": "引导条目",
      "items": {
        "type": "object",
        "description": "引导条目",
        "anyOf": [
          {
            "required": [
              "label",
              "hint"
            ]
          },
          {
            "required": [
              "question",
              "points"
            ]
          }
        ],
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string",
            "minLength": 4,
            "maxLength": 22,
            "description": "带轴前缀的简短 label,如「X轴:用户对 HiRes 的认知深度」「Y轴:设备投入档位」「分布:群体聚集象限」。前缀「X轴/Y轴/分布」由 LLM 自行书写。"
          },
          "hint": {
            "type": "string",
            "minLength": 4,
            "maxLength": 36,
            "description": "一句话解读,告诉读者如何在矩阵上读出这条信息,如「横向越靠右 = 越能讲清 HiRes 的价值」。"
          },
          "question": {
            "type": "string",
            "minLength": 2,
            "maxLength": 36,
            "description": "兼容旧字段。renderer 会作为 label 渲染。"
          },
          "points": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "description": "兼容旧字段。renderer 会用 / 拼接后作为 hint 渲染。",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 16
            }
          }
        }
      }
    }
  }
}
