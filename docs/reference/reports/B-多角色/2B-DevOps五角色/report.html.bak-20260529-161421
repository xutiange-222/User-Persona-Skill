<!DOCTYPE html>
<!--
  user-persona-v8 共享骨架(v1)
  ------------------------------------------------------------
  职责:HTML 文档框架 + meta-bar + persona-nav + tooltip + JS。
  不负责:任何画像主体内容(单页/双页/tab/矩阵/旅程图)。
        各种呈现方式通过 [slot] slot 注入。

  Slot 占位符(render_html.py 用 string replace 填充):
    [slot]            — "2b" / "2c" / "2d"
    [slot]          — "high" / "mid" / "low"
    [slot]    — 2C 时填 "--color-accent: var(--accent-XXX)";其他主题填空字符串
    [slot]            — <title> 标签内容
    [slot]     — 顶部主标题
    [slot] — 顶部右侧元信息("X 个画像 · 来源 Y 份访谈 · 日期")
    [slot]      — 多画像 tab,单画像时填空字符串
    [slot]     — 主体内容,具体子模板渲染产物

  发布期:render_html.py 把 _design-tokens.css 和 _components.css 内联到 <style> 块,
        产出单文件 HTML,可邮件分发/归档。
-->
<html lang="zh-CN" data-theme="2b" data-density="high" style="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DevOps 平台多角色用户画像 — 5 角色</title>

  <!-- 开发期外链;发布期会被 render_html.py 内联进 <style> 块 -->
  <link rel="stylesheet" href="_design-tokens.css">
  <link rel="stylesheet" href="_components.css">

  <style>
    /* ============ _base 自己的样式(全局布局 + 共享外壳) ============ */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      padding: var(--space-8);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-7);
    }

    /* ---- 顶部元信息条 ---- */
    .report-meta-bar {
      width: 100%;
      max-width: var(--canvas-max-w);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 var(--space-3);
      color: var(--color-text-secondary);
      font-size: var(--text-lg);
    }

    .report-meta-title {
      font-size: var(--text-2xl);
      font-weight: var(--font-semibold);
      color: var(--color-text-primary);
    }

    .report-meta-info {
      font-size: var(--text-lg);
      color: var(--color-text-secondary);
    }

    /* ---- 多画像导航 tab(单画像时容器不渲染) ---- */
    .persona-nav {
      width: 100%;
      max-width: var(--canvas-max-w);
      display: flex;
      gap: var(--space-3);
      flex-wrap: wrap;
    }

    .nav-btn {
      padding: var(--space-2) var(--space-7);
      font-size: var(--text-lg);
      border: 1px solid var(--color-border-subtle);
      background: var(--color-bg-card);
      color: var(--color-text-primary);
      border-radius: var(--radius-pill);
      cursor: pointer;
      transition: all 0.15s;
      font-family: inherit;
    }

    .nav-btn:hover {
      background: var(--color-primary-light);
      border-color: var(--color-accent);
      color: var(--color-accent);
    }


    .persona-nav .nav-pair {
      display: inline-flex;
      align-items: stretch;
      gap: 0;
    }

    .persona-nav .nav-pair .nav-btn-persona {
      border-top-right-radius: 0;
      border-bottom-right-radius: 0;
      margin-right: 0;
    }

    .persona-nav .nav-pair .nav-btn-journey {
      border-left: 0;
      border-top-left-radius: 0;
      border-bottom-left-radius: 0;
      padding-left: var(--space-4);
      padding-right: var(--space-5);
    }
    .nav-btn.active {
      background: var(--color-accent);
      color: var(--color-text-inverse);
      border-color: var(--color-accent);
    }

    /* ---- 共享外壳:16:9 画布(内部布局由 _components.css 按主题定义) ---- */
    .persona-slide {
      width: 100%;
      max-width: var(--canvas-max-w);
      aspect-ratio: var(--canvas-aspect);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-md);
      background: var(--color-bg-canvas-right);
      overflow: hidden;
      position: relative;
    }

    /* 多画像时:除当前 active 外,其他 slide 隐藏 */
    .persona-slide:not(.active) {
      display: none;
    }

    /* ============ 全局 Tooltip(hover 显示原话证据) ============ */
    [data-evidence]:not([data-evidence=""]) {
      cursor: help;
    }

    #global-tooltip {
      position: fixed;
      background: var(--tooltip-bg);
      color: var(--tooltip-text);
      padding: var(--space-5) var(--space-6);
      border-radius: var(--radius-lg);
      font-size: var(--text-base);
      line-height: var(--leading-relaxed);
      max-width: 380px;
      z-index: 9999;
      box-shadow: var(--shadow-tooltip);
      pointer-events: none;
      display: none;
      opacity: 0;
      transition: opacity 0.12s;
    }

    #global-tooltip.visible {
      display: block;
      opacity: 1;
    }

    #global-tooltip .tip-quote {
      padding: var(--space-2) 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    #global-tooltip .tip-quote:last-child { border-bottom: none; }
    #global-tooltip .tip-quote:first-child { padding-top: 0; }

    #global-tooltip .tip-text {
      color: var(--tooltip-text);
      font-style: italic;
    }

    #global-tooltip .tip-source {
      color: var(--tooltip-source);
      font-size: var(--text-sm);
      margin-top: var(--space-1);
    }

    #global-tooltip::after {
      content: "";
      position: absolute;
      bottom: -6px;
      left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: var(--tooltip-bg);
    }
  </style>
</head>

<body>
